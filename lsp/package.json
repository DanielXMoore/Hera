{
  "name": "hera",
  "displayName": "Hera",
  "description": "Hera Language Server",
  "icon": "images/hera.png",
  "version": "0.1.7-pre.1",
  "license": "MIT",
  "publisher": "DanielX",
  "repository": {
    "type": "git",
    "url": "https://github.com/DanielXMoore/hera.git"
  },
  "categories": [],
  "engines": {
    "vscode": "^1.65.0"
  },
  "activationEvents": [
    "onLanguage:hera"
  ],
  "main": "./dist/extension",
  "contributes": {
    "languages": [
      {
        "id": "hera",
        "extensions": [
          ".hera"
        ],
        "configuration": "./syntaxes/hera-configuration.json"
      },
      {
        "id": "hera-markdown-injection"
      }
    ],
    "grammars": [
      {
        "language": "hera",
        "scopeName": "source.hera",
        "embeddedLanguages": {
          "meta.embedded.block.javascript": "javascript"
        },
        "path": "./syntaxes/hera.json"
      },
      {
        "language": "hera-markdown-injection",
        "scopeName": "markdown.hera.codeblock",
        "path": "./syntaxes/codeblock.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.hera": "hera"
        }
      }
    ],
    "configuration": {
      "title": "Hera",
      "properties": {
        "hera.language": {
          "type": "string",
          "enum": [
            "javascript",
            "typescript",
            "civet"
          ],
          "default": "javascript",
          "description": "The language used for handlers and code blocks in .hera files."
        }
      }
    }
  },
  "mocha": {
    "extension": [
      "civet"
    ],
    "require": [
      "@danielx/civet/register"
    ],
    "reporter": "spec",
    "recursive": true,
    "spec": [
      "test"
    ]
  },
  "c8": {
    "all": true,
    "reporter": [
      "lcov",
      "text"
    ],
    "extension": [
      ".civet"
    ],
    "include": [
      "source/"
    ]
  },
  "scripts": {
    "build": "civet .esbuild.civet",
    "e2e": "sh ./scripts/e2e.sh",
    "lint": "eslint ./src --ext .ts,.tsx",
    "package": "civet .esbuild.civet && vsce package --no-dependencies",
    "vsce-publish": "civet .esbuild.civet && vsce publish --no-dependencies",
    "test": "c8 mocha",
    "watch": "civet .esbuild.civet --watch"
  },
  "devDependencies": {
    "@danielx/civet": "0.11.6",
    "@danielx/hera": "workspace:*",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.115.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vscode/test-electron": "^2.5.2",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "mocha": "^11.7.5",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vsce": "^2.15.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
