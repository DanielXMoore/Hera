* as vscode from vscode
* as assert from assert
{ getDocUri, activate } from ./helper

suite 'Diagnostics', =>
  test 'Reports a parse error for invalid Hera grammar', async =>
    docUri := getDocUri('invalid.hera')
    await activate(docUri)

    diagnostics := vscode.languages.getDiagnostics(docUri)

    assert.ok diagnostics.length >= 1, 'Expected at least one diagnostic'
    assert.strictEqual diagnostics[0].severity, vscode.DiagnosticSeverity.Error
    assert.strictEqual diagnostics[0].source, 'hera'

  test 'Reports no diagnostics for valid Hera grammar', async =>
    docUri := getDocUri('valid.hera')
    await activate(docUri)

    diagnostics := vscode.languages.getDiagnostics(docUri)

    assert.strictEqual diagnostics.length, 0, 'Expected no diagnostics for valid grammar'
