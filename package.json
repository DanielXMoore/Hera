{
  "name": "@danielx/hera",
  "version": "0.9.1",
  "description": "Small and fast parsing expression grammars",
  "devDependencies": {
    "@danielx/civet": "0.11.6",
    "@danielx/hera-previous": "npm:@danielx/hera@0.9.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "benchmark": "^2.1.4",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "microtime": "^3.1.1",
    "mocha": "^11.7.5",
    "typescript": "^6.0.2"
  },
  "homepage": "https://danielx.net/hera/docs/README.html",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanielXMoore/hera.git"
  },
  "mocha": {
    "extension": [
      "civet"
    ],
    "require": [
      "@danielx/hera-previous/register/tsc",
      "@danielx/civet/register"
    ],
    "reporter": "dot",
    "recursive": true,
    "spec": [
      "test"
    ]
  },
  "c8": {
    "100": true,
    "check-coverage": true,
    "reporter": [
      "lcov",
      "text"
    ],
    "extension": [
      ".civet",
      ".hera",
      ".mts",
      ".ts"
    ],
    "exclude": [
      "build/",
      "dist/",
      "test/"
    ]
  },
  "scripts": {
    "prepublishOnly": "pnpm build && pnpm test",
    "benchmark": "civet ./perf/compare.civet",
    "build": "bash build/compile",
    "build:rules": "NODE_OPTIONS='--import=@danielx/hera-previous/register/tsc' civet build/rules.civet",
    "test": "bash ./build/test",
    "test:esbuild-plugin": "cd ./esbuild-example && node ./build-and-use-example.cjs && node ./test-import.mjs && node ./test-require.cjs",
    "test:loaders": "bash ./loader-examples/test-examples",
    "test:typed-parser-samples": "bash build/typed-parser-samples && tsc -p tsconfig.parsers.json"
  },
  "bin": {
    "hera": "dist/hera"
  },
  "files": [
    "dist/"
  ],
  "main": "dist/main.js",
  "exports": {
    ".": "./dist/main.js",
    "./lib": "./dist/machine.js",
    "./esbuild-plugin": "./dist/esbuild.js",
    "./esbuild": "./dist/esbuild.js",
    "./register": "./dist/register.js",
    "./register/cjs": "./dist/register/cjs.js",
    "./register/esm": "./dist/esm.js",
    "./register/tsc": "./dist/register/tsc/index.js",
    "./register/tsc/esm": "./dist/register/tsc/esm.js",
    "./register/tsc/cjs": "./dist/register/tsc/cjs.js",
    "./register/civet": "./dist/register/civet/index.js",
    "./register/civet/cjs": "./dist/register/civet/cjs.js",
    "./register/civet/esm": "./dist/register/civet/esm.js",
    "./esm": "./dist/esm.js",
    "./*": "./*",
    "./dist/*": "./dist/*",
    "./hera-types": "./dist/hera-types.js"
  },
  "types": "dist/main.d.ts",
  "packageManager": "pnpm@10.33.0"
}
