assert from assert
{ decompile, grammarToEBNF } from ../source/util.civet
{parse} from ../source/main.civet
{ readFile } from ./helper.civet
heraGrammarAST := JSON.parse readFile "source/rules.json"

// Decompile/parse round trips can preserve handler text while shifting source
// offsets, so these comparisons intentionally ignore handler locs.
normalizeHandlerLocs := (value) ->
  if Array.isArray(value)
    return value.map normalizeHandlerLocs

  if value and typeof value is "object"
    if "f" in value and "$loc" in value
      return Object.fromEntries(
        Object.entries(value)
          .filter ([key]) ->
            key != "$loc"
          .map ([key, entry]) ->
            [key, normalizeHandlerLocs(entry)]
      )

    return Object.fromEntries(
      Object.entries(value)
        .map ([key, entry]) ->
          [key, normalizeHandlerLocs(entry)]
    )

  return value

// AST doesn't store comments, so we can't reproduce them in decompilation
normalizeGrammarSource := (source: string) ->
  source
    .replace(/^[ \t]*#.*(?:\r?\n|\r)?/gm, "")
    .replace(/[ ]+\n/g, '\n')
    .replace(/(?:\r?\n|\r){3,}/g, '\n\n')

describe "util", ->
  /*
    If you've changed source/hera.hera run `pnpm build:rules` to update
    source/rules.json
  */
  it "should parse decompiled rules", ->
    grammar .= decompile({ ...heraGrammarAST.rules, [:code]: heraGrammarAST.code })

    // console.log grammar
    parsedRules := parse grammar
    // console.log parsedRules, rules

    assert.deepEqual normalizeHandlerLocs(parsedRules), normalizeHandlerLocs(heraGrammarAST.rules)

    src := readFile("source/hera.hera")
    assert.equal normalizeGrammarSource(grammar), normalizeGrammarSource(src)

  it "should convert grammar rules to ebnf", ->
    grammarToEBNF(heraGrammarAST.rules)

  it "should decompile nested choices", ->
    rules := parse """
      Rule
        ("A" / "C") ("B" / "D")
        "Z" -> "z"
        "N" -> 0
    """

    decompiled := decompile rules
    assert.deepEqual normalizeHandlerLocs(parse(decompiled)), normalizeHandlerLocs(rules)

  it "should decompile literal undefined", ->
    grammar := """
      Rule
        "X" -> undefined

    """
    rules := parse grammar
    assert.equal decompile(rules), grammar

  it "decompiles to an object format", ->
    grammar := """
      Rule
        "X" -> {a: 1, b: null}

    """
    rules := parse grammar

    assert.equal decompile(rules), grammar

  it "should decompile named rule", ->
    grammar := """
      Rule
        N:x A:y ->
          return x + 1

    """
    rules := parse grammar

    assert.equal decompile(rules), grammar
    assert grammarToEBNF(rules)

  it "should decompile named rule", ->
    grammar := """
      Rule
        N:x ->
          return x + 1

    """
    rules := parse grammar

    assert.equal decompile(rules), grammar

  it "should decompile type annotated rule", ->
    grammar := """
      Rule
        N:x :: number ->
          return parseInt(x, 0)

    """
    rules := parse grammar

    assert.equal decompile(rules), grammar

  it "should throw an error when decompiling an unknown format", ->
    rules := parse """
      Rule
        "X" -> 0
    """

    rules.Rule[2] = {
      yo: "wat"
    }

    assert.throws ->
      decompile rules
    , /Unknown handler format/

  it "should throw an error when decompiling an invalid handler", ->
    rules := parse """
      Rule
        "X" -> 0
    """

    rules.Rule[2] = {
      f: 0
    }

    assert.throws ->
      decompile rules
    , /Unknown handler format/

  it "should throw an error when decompiling an unknown rule type", ->
    rules := parse """
      Rule
        "X" -> 0
    """

    rules.Rule[0] = "XXX"

    assert.throws ->
      decompile rules
    , /Unknown/

  it "should throw an error when converting unknown rule to ebnf", ->
    rules := parse """
      Rule
        "X" -> 0
    """

    rules.Rule[0] = "XXX"

    assert.throws ->
      grammarToEBNF rules
    , /Unknown/
