assert from assert
{ readFile } from ./helper.civet
hera, { compile, generate, modImport, parse } from ../source/main.civet
{ transpileTsToJs } from ../source/register/tsc/transpile.civet

describe "Hera", ->
  it "should do math example", ->
    grammar := readFile("samples/math.hera")
    parser := generate(grammar)

    result := parser.parse """
      8 + 3 / (2 + 5)
    """

    assert.equal result, 8 + 3 / 7

  it "should do url example", ->
    grammar := readFile("samples/url.hera")
    parser := generate(grammar)

    {scheme, fragment, host, path, port, query} := parser.parse """
      http://danielx.net:443/%21?query#fragment
    """

    assert.equal scheme, "http"
    assert.equal host, "danielx.net"
    assert.equal port, "443"
    assert.equal path, "/!"
    assert.equal query, "query"
    assert.equal fragment, "fragment"

  it "should parse code example", ->
    grammar := readFile("samples/code.hera")
    parser := generate(grammar)

    assert.equal parser.test, "hello"

    parser.parse "a"

  it "should consume blank lines as part of EOS", ->
    grammar := """
      Grammar
        Rule+ ->
          a = 5

          return a

      Rule
        Name StringLiteral? EOS (Indent Choice)+

    """

    assert hera.parse(grammar)

  it "should handle comments", ->
    grammar := """
      # Comment!
      # Comment


      Grammar # Comment!
        Rule # Another Comment!
      # 2Comment!
      Rule#Comment
        "a"#rad

      # comment
    """

    parser := generate(grammar)
    assert parser.parse("a")

  it "should preserve hash-prefixed handler lines", ->
    rules := hera.parse """
      Rule
        "a" ->
          # comment
          return 1
          # comment 2
    """

    assert typeof rules.Rule[2] is "object" and "f" in rules.Rule[2]
    assert.equal rules.Rule[2].f, "    # comment\n    return 1\n    # comment 2"

  it "should preserve hash-prefixed inline handler lines", ->
    rules := hera.parse """
      Rule
        "a" -> {
          # comment 1
          value: 1,
          # comment 2
        }.value
    """

    assert typeof rules.Rule[2] is "object" and "f" in rules.Rule[2]
    assert.equal rules.Rule[2].f, "{\n    # comment 1\n    value: 1,\n    # comment 2\n  }.value"

  it "should handle rules that are aliases", ->
    grammar := """
      Grammar
        Alias Alias*

      Alias
        Terminal

      Terminal
        "."
    """

    parser := generate(grammar)
    assert parser.parse(".")

  it "should recursively generate itself", ->
    heraSrc := readFile('source/hera.hera')
    { parse: newHeraParse } := generate heraSrc, transpile: transpileTsToJs

    assert.deepEqual newHeraParse(heraSrc), parse(heraSrc)

    grammar := """
      Grammar
        Rule+

      Rule
        Name StringLiteral? EOS (Indent Choice)+

    """
    assert.deepEqual(newHeraParse(grammar), parse(grammar))

  it "should sourcemap", ->
    {code, sourceMap} := compile 'Rule\n  "a"', sourceMap: true

    assert code
    assert sourceMap

  it "should source map rule block handlers from the preserved line start", ->
    grammar := """
      Rule
        "abc" ->
          return 1
          x()
    """
    {code, sourceMap} := compile grammar, sourceMap: true
    lines := code.split("\n")
    returnLine := lines.findIndex((line) => line.includes("return 1"))
    callLine := lines.findIndex((line) => line.includes("x()"))

    assert returnLine >= 0, "compiled output should contain 'return 1'"
    assert callLine >= 0, "compiled output should contain 'x()'"

    assert.deepEqual sourceMap.lines[returnLine].find((entry) => entry.length > 1), [0, 0, 2, 0]
    assert.deepEqual sourceMap.lines[callLine].find((entry) => entry.length > 1), [0, 0, 3, 0]

  it "should sourcemap fenced code blocks", ->
    heraSrc := "```\nconst injectedCodeBlockValue = 12345;\n```\n\nRule\n  \"a\""
    {code, sourceMap} := compile heraSrc, sourceMap: true

    outputLine := code
      .split("\n")
      .findIndex (line) -> line.includes "const injectedCodeBlockValue = 12345;"

    assert.notEqual outputLine, -1
    assert sourceMap.lines[outputLine].some (entry) ->
      entry.length is 4 and entry[2] is 1 and entry[3] is 0

  it "should source map one-line handlers", ->
    grammar := """
      Start
        \"a\":left \"b\":right -> [left, right]
        /(c+)(d+)/ -> [$1, $2]
        \"t\" -> true
        \"n\" -> null
    """
    {code, sourceMap} := compile grammar, sourceMap: true
    lines := code.split("\n")
    sequenceLine := lines.findIndex (line) -> line.includes "return [left, right]"
    regexLine := lines.findIndex (line) -> line.includes "return [$1, $2]"
    trueLine := lines.findIndex (line) -> line.includes "return true"
    nullLine := lines.findIndex (line) -> line.includes "return null"

    assert sequenceLine >= 0, "compiled output should contain 'return [left, right]'"
    assert regexLine >= 0, "compiled output should contain 'return [$1, $2]'"
    assert trueLine >= 0, "compiled output should contain 'return true'"
    assert nullLine >= 0, "compiled output should contain 'return null'"

    assert sourceMap.lines[sequenceLine].some (entry) ->
      entry.length is 4 and entry[2] is 1 and entry[3] is 24
    assert sourceMap.lines[regexLine].some (entry) ->
      entry.length is 4 and entry[2] is 2 and entry[3] is 16
    assert sourceMap.lines[trueLine].some (entry) ->
      entry.length is 4 and entry[2] is 3 and entry[3] is 9
    assert sourceMap.lines[nullLine].some (entry) ->
      entry.length is 4 and entry[2] is 4 and entry[3] is 9

  it "should compile to ts", ->
    heraSrc := readFile('source/hera.hera')
    tsSrc := compile heraSrc, types: true

    assert tsSrc

  it "should add inline source map", ->
    heraSrc := readFile('source/hera.hera')
    tsSrc := compile heraSrc, types: true, inlineMap: true

    assert tsSrc.includes('//# sourceMappingURL=data:application/json;base64')

  it "should annotate simple regexp types when compiling", ->
    heraSrc := """
      Rule
        /abc/
    """
    tsSrc := compile hera.parse(heraSrc), types: true

    assert tsSrc.includes('$R<["abc"]>')

  it "should annotate rules with types with handlers ", ->
    heraSrc := """
      Rule
        "abc" ::MyType ->
          return new MyType
    """
    tsSrc := compile hera.parse(heraSrc), types: true

    assert tsSrc.includes('function Rule(ctx: ParserContext, state: ParseState): MaybeResult<MyType>')

  it "unions the types of a choice rule whose alternatives all declare return types", ->
    heraSrc := """
      Rule
        "a" ::A ->
          return "a" as any as A
        "b" ::B ->
          return "b" as any as B
    """
    tsSrc := compile hera.parse(heraSrc), types: true

    assert tsSrc.includes('function Rule(ctx: ParserContext, state: ParseState): MaybeResult<A | B>')

  it "numbered regex groups in mappings", ->
    grammar := """
      Start
        Group1
        Group2
        Group3
        Group4

      Group1
        /(a+)(b+)/ -> [$1, $2]

      Group2
        /(c+)(d+)/ ->
          return [$1, $2];

      Group3
        /123((456)789)/ -> [$3, $1, $2, $0]

      Group4
        /pp(qq)/ ->
          return $0 + $1
    """

    {parse} := generate(grammar)

    assert.deepEqual parse("aab"), ["aa", "b"]
    assert.deepEqual parse("cdd"), ["c", "dd"]
    assert.deepEqual parse("123456789"), [undefined, "456789", "456", "123456789"]
    assert.deepEqual parse("ppqq"), "ppqqqq"

  it "regex that may sometimes be empty with +", ->
    grammar := """
      Start
        Re+ ->
          return $0.join('')

      Re
        /a|b?/
    """

    {parse} := generate(grammar)
    assert.deepEqual parse("ab"), "ab"
    assert.deepEqual parse(""), ""
    assert.deepEqual parse("bb"), "bb"

  it "transitive regex", ->
    grammar := """
      Start
        Group*

      Group
        /(a?)(b+)c*/
    """

    {parse} := generate(grammar)

    assert.deepEqual parse(""), []
    assert.deepEqual parse("ab"), ["ab"]
    assert.deepEqual parse("ababccbc"), ["ab", "abcc", "bc"]

  it "should parse bare character classes as regexes", ->
    rules := parse """
      Rule
        [a-z]+[1-9]*

      Flags
        [dgimsuy]

      Name
        [_a-zA-Z][_a-zA-Z0-9]*

      Quants
        [0-9]{3,4}

      Quant2
        [a]{2}
    """

    assert.deepEqual rules.Rule, ["R", "[a-z]+[1-9]*"]
    assert.deepEqual rules.Flags, ["R", "[dgimsuy]"]
    assert.deepEqual rules.Name, ["R", "[_a-zA-Z][_a-zA-Z0-9]*"]
    assert.deepEqual rules.Quants, ["R", "[0-9]{3,4}"]
    assert.deepEqual rules.Quant2, ["R", "[a]{2}"]

  it "should parse simple grammars", ->
    {parse} := generate """
      Rule
        "A"+
        "B"+

    """

    parse "AAAAAA"
    parse "BBB"

    assert.throws ->
      parse "BBA"

    assert.throws ->
      parse "AAB"

  describe "-> Structural Result", ->
    it "should map to literals", ->
      {parse} := generate """
        Rule
          I J K N F T

        I
          "" -> 7

        J
          "" -> -3.1

        K
          "" -> 2.7

        N
          "" -> null

        F
          "" -> false

        T
          "" -> true
      """

      assert.deepEqual parse(""), [7, -3.1, 2.7, null, false, true]

    it "should properly encode string literals in object values", ->
      {parse} := generate """
        Rule
          "" -> "\\n"
      """

      assert.deepEqual parse(""), "\n"

    it "should allow for bare undefined", ->
      {parse} := generate """
        Rule
          "" -> undefined
      """

      assert.deepEqual parse(""), undefined

    it "should map regexp groups into the structure", ->
      {parse} := generate """
        Rule
          /(a)(b)(c)/ -> [$2, $3, $1]
      """

      assert.deepEqual ["b", "c", "a"], parse "abc"

    it "should map sequence items into the structure", ->
      {parse} := generate """
        Rule
          "A" "B" "C" -> [$2, $3, $1]
      """

      assert.deepEqual ["B", "C", "A"], parse "ABC"

    it "should map array of sequence as $0", ->
      {parse} := generate """
        Rule
          "A" "B" "C" -> $0
      """

      assert.deepEqual ["A", "B", "C"], parse "ABC"

    it "should map the entire result as $1", ->
      {parse} := generate """
        Rule
          Sub* -> ["T", $1]

        Sub
          "A" "B"
      """

      assert.deepEqual ["T", []], parse ""
      assert.deepEqual ["T", [["A", "B"]]], parse "AB"
      assert.deepEqual ["T", [["A", "B"], ["A", "B"]]], parse "ABAB"

    it "should work with nested structures", ->
      {parse} := generate """
        Rule
          "A" "B" "C" -> [$2, [$3, [$3, $1]], $1]
      """

      assert.deepEqual ["B", ["C", ["C", "A"]], "A"], parse "ABC"

    it "should work with basic types", ->
      {parse} := generate """
        Rule
          "" -> [true, false, null, undefined, 0xff, 0xFF, 7, "A", []]
      """

      assert.deepEqual [true, false, null, undefined, 0xff, 0xFF, 7, "A", []], parse ""

    it "should handle multi-line arrays", ->
      {parse} := generate """
        Rule
          "" -> [
            [
              1,
              2
            ],
            3
          ]
      """

      assert.deepEqual [[1, 2], 3], parse ""

    it "should allow postfix after multi-line array inline handlers", ->
      {parse} := generate """
        Rule
          "" -> [
            "a",
            "b"
          ].join("")
      """

      assert.equal "ab", parse ""

    it "should map object structures", ->
      {parse} := generate """
        Rule
          "" -> [{}, {a: true}, {b: [0], c: 1}]
      """

      assert.deepEqual [{}, {a: true}, {b: [0], c: 1}], parse ""

    it "should map nested structures", ->
      {parse} := generate """
        Rule
          "a" -> [{b: [{x: 2, y: [{z: -1.3}]}, [{}]], c: 1}]
          "b" -> {b: [{x: 2, y: [{z: -1.3}]}, [{}]], c: 1}
      """

      assert.deepEqual parse("a"), [{b: [{x: 2, y: [{z: -1.3}]}, [{}]], c: 1}]
      assert.deepEqual parse("b"), {b: [{x: 2, y: [{z: -1.3}]}, [{}]], c: 1}

    it "should map object shorthand", ->
      {parse} := generate """
        Rule
          A:a B:b -> {a, b}
        A
          "a" -> 1
        B
          "b" -> 2
      """

      assert.deepEqual parse("ab"), {"a": 1, "b": 2}

    it "should work with multi-line objects", ->
      {parse} := generate """
        Rule
          "a" -> {
            b: [{x: 2, y: [{z: -1.3}]}, [{}]],
            c: 1
          }
      """

      assert.deepEqual {b: [{x: 2, y: [{z: -1.3}]}, [{}]], c: 1}, parse "a"

    it "should allow postfix after multi-line object inline handlers", ->
      {parse} := generate """
        Rule
          "" -> {
            a: 1,
            b: 2
          }.a
      """

      assert.equal 1, parse ""

  describe "$ Prefix Operator: result text", ->
    it "should return the whole text of the match", ->
      {parse} := generate """
        Rule
          $("AAA" "B" "C")
      """

      assert.equal "AAABC", parse "AAABC"

    it "should keep pass through fail states", ->
      {parse} := generate """
        Rule
          $A / $B
        A
          [aA]+
        B
          [bB]+
      """

      assert.equal "aaAaa", parse "aaAaa"
      assert.equal "bBbb", parse "bBbb"
      assert.throws ->
        parse "c"
      , /Expected:\s*A/

    it "should correctly span repetitions", ->
      {parse} := generate """
        Rule
          $("A" "B" "C")*
      """

      assert.equal "ABCABC", parse "ABCABC"
      assert.equal "", parse ""

    it "should handle nested rules", ->
      {parse} := generate """
        RegExpLiteral
          "/" !_ $RegExpCharacter* "/" -> ["R", $3]
          CharacterClassExpression

        CharacterClassExpression
          $CharacterClass+ -> ["R", $1]

        RegExpCharacter
          [^\\/\\\\]+
          EscapeSequence

        CharacterClass
          "[" CharacterClassCharacter* "]" Quantifier?

        CharacterClassCharacter
          [^\\]\\\\]+
          EscapeSequence

        Quantifier
          /[?+*]|\\{\\d+(,\\d+)?\\}/

        EscapeSequence
          Backslash . ->
            return '\\\\' + $2

        Backslash
          "\\\\"

        _
          [ \\t]+
      """

      assert.deepEqual ["R", "[abc][bc]"], parse "[abc][bc]"
      assert.deepEqual ["R", "[^]a\\[\\^b]"], parse "/[^]a\\[\\^b]/"

  it "should work with assertions", ->
    {parse} := generate """
      Rule
        &"B" "C"+
        &"A" "A"+ ->
          return $2
    """

    assert.equal parse("AAAAAA").length, 6

  it "assertions should return true as success value", ->
    {parse} := generate """
      Rule
        &"A":a "A"+ ->
          return $1
    """

    assert.equal parse("AAAAAA"), true

  it "negative assertions should return true as success value", ->
    {parse} := generate """
      Rule
        !"B":a "A"+ ->
          return $1
    """

    assert.equal parse("AAAAAA"), true

  it "optional assertion returns true when present, undefined when not", ->
    {parse} := generate """
      Rule
        (&A)?:b A? "B" ->
          return b

      A
        "A"
    """

    assert.equal parse("AB"), true
    assert.equal parse("B"), undefined

  it "should have string handlers", ->
    {parse} := generate """
      Rule
        "A"+ -> "a"
        "B"+ -> "b"
    """

    assert.equal parse("AAAAAA"), "a"
    assert.equal parse("BBB"), "b"

  describe "starting rules", ->
    it "should be able to parse from any starting rule", ->
      assert hera.parse "[]",
        startRule: "CharacterClassExpression"

    it "should throw an error when a non-existent starting rule is given ", ->
      assert.throws ->
        hera.parse "",
          startRule: "DoesNotExist"
      , /Could not find rule/

  it "should tokenize", ->
    {parse} := generate """
      Rule
        &"D" /D/ -> "d"
        !"C" A+ -> "a"
        "B"+ -> "b"

      A
        "A"
    """

    result .= parse("AAAAAA", tokenize: true)
    assert.equal result.children[1].length, 6

    result = parse("BBB", tokenize: true)
    assert.equal result.children.length, 3

    result = parse("D", tokenize: true)
    // TODO: Regex tokenize?
    // assert.deepEqual result.children[1], 1

    // tokenize shouldn't blow up regular parsing
    assert.equal parse("BBB"), "b"

  it "should skip infinite zero width loops", ->
    {parse} := generate """
      Rule
        ""* "a"
    """

    result := parse("a")
    assert.deepEqual result, [[], "a"]

  it "should throw an error when there is unconsumed input", ->
    {parse} := generate """
      Rule
        "a"
    """

    assert.throws ->
      parse("aa")
    , /Unconsumed input/

  it "should throw an error when there are no failed expectations but still input remaining", ->
    {parse} := generate """
      Rule
        ""
    """

    assert.throws ->
      parse("bb")
    , /Unconsumed input/

  it "throws an error when parsing non-strings", ->
    {parse} := generate """
      Rule
        "a"
    """

    assert.throws ->
      parse(undefined as! string)
    , /Input must be a string/

  it "should throw an error when running out of input", ->
    {parse} := generate """
      Rule
        "aaaa"
        EOF
      EOF
        !/[\s\S]/
    """

    assert.throws ->
      parse "aaa"
    , /Rule "aaaa"/

  it "should compile object literal handlers", ->
    rules := hera.parse """
      Rule
        "a" -> {a: [true, "b", $0]}
    """

    assert compile rules

  it "should reuse duplicated regexp literals", ->
    code := compile hera.parse("""
      Rule
        /a+/
        /a+/
    """)

    assert code.includes('const $R0 = $R(')
    assert !code.includes('const $R1 = $R(')

  it "should throw an error when encountering an invalid handler", ->
    rules := hera.parse """
      Rule
        "a"
    """

    rules.Rule[2] = {
      f: 0
    }

    assert.throws ->
      compile(rules)
    , /unknown handler format/

  it "should throw an error when handlers are malformed", ->
    rules := hera.parse """
      Rule
        "a"
    """

    rules.Rule[2] = { yo: "wat" }

    assert.throws ->
      compile(rules)
    , /unknown handler format/

  it "throw an error when encountering an unknown operator", ->
    rules := hera.parse """
      Rule
        "a"
    """

    // Hack in an unknown operator
    rules.Rule[0] = "QQ"

    assert.throws ->
      compile(rules)
    , /QQ/

  it "should error when referencing an unknown rule", ->
    assert.throws ->
      // TODO: throw during compile or even at end of parse?
      {parse} := generate """
        Rule
          "aaaa"
          EOF
      """

      parse "b"
    , /EOF/

  it "should give accurate error message with multiline input", ->
    {parse} := generate """
      Rule
        Line+
      Line
        "aaaa" EOL
      EOL
        /\r\n|\n/
    """

    assert.throws ->
      parse """
        aaaa
        aaaa
        aaaa
        aaa
      """
    , /4:1/

  it "should annotate errors with meta data", ->
    {parse} := generate """
      Rule
        Line+
      Line
        "aaaa" EOL
      EOL
        /\r\n|\n/
    """

    assert.throws ->
      parse """
        aaaa
        aaaa
        aaaa
        aaa
      """
    , (thrown) ->
      assert.equal thrown.line, 4
      assert.equal thrown.column, 1
      assert.equal thrown.offset, 15
      assert.equal thrown.message, """
        <anonymous>:4:1 Failed to parse
        Expected:
        \tLine "aaaa"
        Found: "aaa"

      """

      return true

  it "should skip rules programmatically", ->
    {parse} := generate """
      Rule
        Skipped
        V

      Skipped
        "" ->
          return $skip

      V
        "" -> true
    """

    assert parse ""

  describe "named parameters", ->
    it "should provide named parameters for a sequence", ->
      {parse} := generate """
        Rule
          A:a B:b ->
            return [a, b]

        A
          "a"

        B
          "b"
      """

      assert.deepEqual parse("ab"), ["a", "b"]

    it "should provide named parameters for a single string", ->
      {parse} := generate """
        A
          "a":a ->
            return a
      """

      assert.equal parse("a"), "a"

    it "should provide named parameters for a single regexp", ->
      {parse} := generate """
        A
          /a+/:a ->
            return a
      """

      assert.equal parse("aaa"), "aaa"

    it "should provide named parameters for an alias", ->
      {parse} := generate """
        Rule
          A:a ->
            return a

        A
          /a+/:a ->
            return a
      """

      assert.equal parse("aa"), "aa"

    it "should allow named parameters in one-line handlers", ->
      {parse} .= generate """
        A
          "a":a -> [a, a]
      """

      assert.deepEqual parse("a"), ["a", "a"]

      {parse} = generate """
        Rule
          A:a B:b -> [b, a]

        A
          [a]+

        B
          [b]+
      """

      assert.deepEqual parse("abb"), ["bb", "a"]

  describe "events", ->
    it "should pass data from enter to exit events", ->
      {parse} := generate """
        Rule
          "a"
      """

      events :=
        enter: (rule, state) ->
          eventLog.push [rule, state]
          return {data: "the data"}
        exit: (rule, state, result, data) ->
          eventLog.push [rule, state, result, data]

      eventLog: unknown[] := []
      parse "a", { events }

      assert.deepEqual eventLog, [
        ["Rule", {
          input: "a",
          pos: 0,
        }]
        ["Rule", {
          input: "a",
          pos: 0,
        }, {
          loc:
            length: 1
            pos: 0
          pos: 1
          value: "a"
        }, "the data"]
      ]

  describe "modImport", ->
    it "should generate module", ->
      {parse} := await modImport """
        Rule
          "a"
      """

      assert parse("a")

  describe "CompilerOptions.language", ->
    it "should default to JS scaffold when language is unset", ->
      grammar := """
        Rule
          "a" ->
            return "ok"
      """
      result := compile(parse(grammar))
      // JS scaffold does not contain ParseState type annotation
      assert.doesNotMatch result, /: ParseState/

    it "should use TS scaffold when language is 'typescript'", ->
      grammar := """
        Rule
          "a" ->
            return "ok" as string
      """
      result := compile(parse(grammar), language: 'typescript')
      // TS scaffold contains ParseState type annotation
      assert.match result, /: ParseState/

    it "should use TS scaffold when language is 'civet'", ->
      grammar := """
        Rule
          "a" ->
            return "ok" as string
      """
      result := compile(parse(grammar), language: 'civet')
      assert.match result, /: ParseState/

    it "should indent inline civet handlers by two spaces", ->
      grammar := """
        Rule
          MaybeNestedTypePrimary:t :: TypeSuffix -> {
            type: "TypeSuffix",
            ts: true,
            t,
          }
      """
      result := compile(parse(grammar), language: 'civet')
      assert.match result, /\n  var t = \$0;\n  return \{\n    type: "TypeSuffix",/m
      assert.match result, /\n  \}\n\}\n/m

    it "should use CJS require() and not ESM import when language is 'civet' and module is not set", ->
      grammar := """
        Rule
          "a" ->
            return "ok" as string
      """
      result := compile(parse(grammar), language: 'civet')
      assert.match result, /require\(/
      assert.doesNotMatch result, /^import /

    it "should use ESM import when language is 'civet' and module is true", ->
      grammar := """
        Rule
          "a" ->
            return "ok" as string
      """
      result := compile(parse(grammar), language: 'civet', module: true)
      assert.match result, /^import /m
      assert.doesNotMatch result, /require\(/

    it "should use JS scaffold when language is 'javascript'", ->
      grammar := """
        Rule
          "a" ->
            return "ok"
      """
      result := compile(parse(grammar), language: 'javascript')
      assert.doesNotMatch result, /: ParseState/

    it "should respect existing types:true when language is unset", ->
      grammar := """
        Rule
          "a" ->
            return "ok" as string
      """
      result := compile(parse(grammar), types: true)
      assert.match result, /: ParseState/

    it "should emit regex-handler positional extraction without TS casts in JS mode", ->
      grammar := """
        Rule
          /(\\d+)/ ->
            return $1
      """
      result := compile(parse(grammar), language: 'javascript')
      // Positional extraction for regex handlers uses `$$m_v = $$r.value;`
      // with no `as any[]` cast in JS mode.
      assert.match result, /const \$\$m_v = \$\$r\.value;/
      assert.doesNotMatch result, /as any\[\]/
